{
  "name": "auto-mate",
  "version": "0.1.0",
  "private": true,
  "description": "auto-mate Chrome extension: record a web form once, then fill it repeatedly from a spreadsheet.",
  "scripts": {
    "test": "node extension/test/run-all.js",
    "build:css": "tailwindcss -i ./extension/sidepanel/input.css -o ./extension/sidepanel/sidepanel.css --minify",
    "dev:css": "tailwindcss -i ./extension/sidepanel/input.css -o ./extension/sidepanel/sidepanel.css --watch",
    "assets:manifest": "node scripts/generate-kanye-manifest.js",
    "generate:icons": "python scripts/generate-icons.py"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "jsdom": "^24.1.0",
    "postcss": "^8.4.49",
    "puppeteer-core": "^22.15.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7"
  }
}
